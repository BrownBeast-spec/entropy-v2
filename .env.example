# Google Gemini API key for LLM integration
GOOGLE_GENERATIVE_AI_API_KEY=

# NCBI/PubMed API credentials
NCBI_API_KEY=
NCBI_EMAIL=

# OpenFDA API key
OPENFDA_API_KEY=

# ─── LLM Configuration ─────────────────────────────────────────────────
# Default model for all agents (format: provider:model-name)
# Supported providers: google, openai, anthropic
# LLM_MODEL=google:gemini-2.5-flash

# Per-agent model overrides (optional — falls back to LLM_MODEL)
# PLANNER_MODEL=openai:gpt-4o
# BIOLOGIST_MODEL=google:gemini-2.5-flash
# CLINICAL_SCOUT_MODEL=anthropic:claude-sonnet-4-20250514
# HAWK_SAFETY_MODEL=google:gemini-2.5-flash
# LIBRARIAN_MODEL=google:gemini-2.5-flash
# GAP_ANALYST_MODEL=openai:gpt-4o
# VERIFIER_MODEL=anthropic:claude-sonnet-4-20250514

# OpenAI API key (required if using openai: provider)
# OPENAI_API_KEY=

# Anthropic API key (required if using anthropic: provider)
# ANTHROPIC_API_KEY=
